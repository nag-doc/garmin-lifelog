def backfill_vo2max(garmin, worksheet, days_back=30):
    """過去のVO2Maxデータを一括で埋める"""
    print(f"\n=== VO2Maxバックフィル開始（過去{days_back}日分）===\n")
    
    # 既存の日付マップを取得
    vals = worksheet.col_values(1)
    existing = {v: i+1 for i, v in enumerate(vals) if len(v) >= 10}
    
    end_date = date.today()
    start_date = end_date - timedelta(days=days_back)
    
    updated_count = 0
    empty_count = 0
    
    current = start_date
    while current <= end_date:
        date_str = current.isoformat()
        
        if date_str not in existing:
            current += timedelta(days=1)
            continue
            
        row_num = existing[date_str]
        
        # 現在のVO2Max値をチェック
        try:
            current_val = worksheet.cell(row_num, 57).value  # 57列目=VO2Max
            if current_val and str(current_val) not in ["", "0"]:
                print(f"[{date_str}] 既にVO2Max={current_val} が存在 → スキップ")
                current += timedelta(days=1)
                continue
        except:
            pass
        
        # Garmin APIからVO2Maxを取得
        try:
            max_metrics = garmin.get_max_metrics(date_str)
            time.sleep(SLEEP_BETWEEN_API)
            
            vo2max = 0
            if isinstance(max_metrics, dict):
                vo2max = max_metrics.get("vo2MaxValue", 0) or max_metrics.get("vo2Max", 0) or 0
            
            if vo2max and vo2max > 0:
                worksheet.update_cell(row_num, 57, vo2max)
                print(f"[{date_str}] ✅ VO2Max={vo2max} を更新（行{row_num}）")
                updated_count += 1
            else:
                print(f"[{date_str}] ⚠️ Garmin上にVO2Maxデータなし")
                empty_count += 1
                
        except Exception as e:
            print(f"[{date_str}] ❌ エラー: {e}")
        
        current += timedelta(days=1)
    
    print(f"\n=== 完了 ===")
    print(f"更新した日数: {updated_count}")
    print(f"データなし（Garmin側）: {empty_count}")

